# Database（本机 Homebrew MySQL，默认 3306）
DATABASE_URL=mysql://pet:pet@127.0.0.1:3306/pet

# 仅 pnpm db:setup:local 需要，填本机 MySQL root 密码（勿提交）
# MYSQL_ROOT_PASSWORD=

# API
PORT=3000
JWT_SECRET=dev-jwt-secret-change-me-in-production
CORS_ORIGIN=http://localhost:3001,http://localhost:8081

# Redis (Phase 1+)
REDIS_URL=redis://localhost:6379

# Admin Web
NEXT_PUBLIC_API_URL=http://localhost:3000

# Media (local dev)
MEDIA_PUBLIC_BASE_URL=http://localhost:3000/uploads
AUTO_MODERATE=true

# OSS (Phase 1)
# OSS_REGION=
# OSS_BUCKET=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=

# SMS (Phase 1)
# SMS_ACCESS_KEY=

# Payments (Phase 2 — dev uses mock channel)
PAYMENTS_MODE=mock
# PAYMENTS_MODE=production
# WECHAT_PAY_APP_ID=
# WECHAT_PAY_MCH_ID=
# ALIPAY_APP_ID=
