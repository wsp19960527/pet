generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  rescuer
  org_admin
  admin
}

enum UserStatus {
  active
  banned
}

enum AdminRole {
  super_admin
  ops_admin
  city_admin
  org_admin
  finance_auditor
  support_agent
}

enum AdminStatus {
  active
  disabled
}

enum AnimalSpecies {
  cat
  dog
  other
}

enum AnimalStatus {
  discovered
  contacting
  rescued
  at_vet
  fostering
  adopted
  deceased
  abandoned
}

enum AnimalModerationStatus {
  pending
  approved
  rejected
  removed
}

enum MediaStatus {
  pending
  approved
  rejected
}

enum WalletOwnerType {
  platform
  animal
  user
}

enum PaymentChannel {
  wechat
  alipay
  mock
}

enum PaymentOrderStatus {
  pending
  paid
  failed
  cancelled
  refunded
}

enum PaymentPurpose {
  tip
  crowdfunding
}

enum LedgerEntryType {
  tip
  crowdfunding
  withdraw
  refund
}

enum CrowdfundingStatus {
  draft
  active
  completed
  cancelled
  failed
}

enum WithdrawalStatus {
  pending
  approved
  rejected
  paid
}

enum MapPoiType {
  station
  volunteer
  hotspot
}

enum OrganizationStatus {
  pending
  approved
  rejected
  suspended
}

enum OrgMemberRole {
  owner
  admin
  member
}

enum EventStatus {
  draft
  published
  cancelled
  completed
}

enum EventRegistrationStatus {
  registered
  cancelled
  attended
}

enum ConversationType {
  direct
}

model User {
  id        String     @id @default(uuid())
  phone     String     @unique
  nickname  String?
  avatarUrl String?    @map("avatar_url")
  cityCode  String?    @map("city_code")
  role      UserRole   @default(user)
  status    UserStatus @default(active)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  animals     Animal[]
  mediaAssets MediaAsset[]
  statusLogs  AnimalStatusLog[]
  interactions Interaction[]
  subscriptions Subscription[]
  paymentOrders PaymentOrder[]
  crowdfundingProjects CrowdfundingProject[]
  cloudAdoptions CloudAdoption[]
  careUpdates CareUpdate[]
  blessings Blessing[]
  userBadges UserBadge[]
  withdrawalRequests WithdrawalRequest[]
  organizationMembers OrganizationMember[]
  organizationsCreated Organization[] @relation("OrganizationCreator")
  eventRegistrations EventRegistration[]
  conversationParticipants ConversationParticipant[]
  messagesSent Message[]

  @@map("users")
}

model City {
  code      String   @id
  name      String
  centerLng Float    @map("center_lng")
  centerLat Float    @map("center_lat")
  zoom      Int      @default(12)
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  animals Animal[]

  mapPois MapPoi[]
  organizations Organization[]
  events Event[]

  @@map("cities")
}

model Animal {
  id                 String                 @id @default(uuid())
  creatorId          String                 @map("creator_id")
  rescuerId          String?                @map("rescuer_id")
  cityCode           String                 @map("city_code")
  species            AnimalSpecies
  status             AnimalStatus           @default(discovered)
  moderationStatus   AnimalModerationStatus @default(pending) @map("moderation_status")
  longitude          Float
  latitude           Float
  addressText        String?                @map("address_text")
  description        String?
  tags               Json                   @default("{}")
  viewCount          Int                    @default(0) @map("view_count")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  creator     User              @relation(fields: [creatorId], references: [id])
  city        City              @relation(fields: [cityCode], references: [code])
  mediaAssets MediaAsset[]
  statusLogs  AnimalStatusLog[]
  subscriptions Subscription[]
  crowdfundingProjects CrowdfundingProject[]
  cloudAdoptions CloudAdoption[]
  careUpdates CareUpdate[]
  blessings Blessing[]

  @@index([cityCode])
  @@index([status])
  @@index([creatorId])
  @@index([moderationStatus])
  @@index([latitude, longitude])
  @@map("animals")
}

model MediaAsset {
  id         String      @id @default(uuid())
  uploaderId String      @map("uploader_id")
  animalId   String?     @map("animal_id")
  objectKey  String      @unique @map("object_key")
  url        String
  mimeType   String      @map("mime_type")
  sizeBytes  Int         @map("size_bytes")
  sortOrder  Int         @default(0) @map("sort_order")
  status     MediaStatus @default(pending)
  createdAt  DateTime    @default(now()) @map("created_at")

  uploader User    @relation(fields: [uploaderId], references: [id])
  animal   Animal? @relation(fields: [animalId], references: [id])

  @@index([animalId])
  @@index([uploaderId])
  @@map("media_assets")
}

model AnimalStatusLog {
  id         String        @id @default(uuid())
  animalId   String        @map("animal_id")
  fromStatus AnimalStatus? @map("from_status")
  toStatus   AnimalStatus  @map("to_status")
  note       String?
  operatorId String        @map("operator_id")
  createdAt  DateTime      @default(now()) @map("created_at")

  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  operator User   @relation(fields: [operatorId], references: [id])

  @@index([animalId, createdAt])
  @@map("animal_status_logs")
}

model Interaction {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  type       String
  content    String?
  parentId   String?  @map("parent_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([targetType, targetId, type])
  @@index([userId])
  @@map("interactions")
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  animalId  String   @map("animal_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@unique([userId, animalId])
  @@index([userId])
  @@index([animalId])
  @@map("subscriptions")
}

model AdminUser {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String      @map("password_hash")
  name         String
  role         AdminRole   @default(ops_admin)
  scopes       Json        @default("{}")
  status       AdminStatus @default(active)
  lastLoginAt  DateTime?   @map("last_login_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  auditLogs AuditLog[]

  @@map("admin_users")
}

model AuditLog {
  id         String    @id @default(uuid())
  operatorId String    @map("operator_id")
  action     String
  targetType String?   @map("target_type")
  targetId   String?   @map("target_id")
  payload    Json?
  ip         String?
  createdAt  DateTime  @default(now()) @map("created_at")

  operator AdminUser @relation(fields: [operatorId], references: [id])

  @@index([operatorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  userId    String?  @map("user_id")
  adminId   String?  @map("admin_id")
  type      String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([adminId])
  @@map("refresh_tokens")
}

model Wallet {
  id           String          @id @default(uuid())
  ownerType    WalletOwnerType @map("owner_type")
  ownerId      String          @map("owner_id")
  balanceCents Int             @default(0) @map("balance_cents")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  ledgerEntries LedgerEntry[]

  @@unique([ownerType, ownerId])
  @@map("wallets")
}

model PaymentOrder {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  amountCents     Int                @map("amount_cents")
  channel         PaymentChannel
  purpose         PaymentPurpose
  refType         String             @map("ref_type")
  refId           String             @map("ref_id")
  status          PaymentOrderStatus @default(pending)
  idempotencyKey  String             @unique @map("idempotency_key")
  providerOrderId String?            @map("provider_order_id")
  paidAt          DateTime?          @map("paid_at")
  metadata        Json               @default("{}")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user          User          @relation(fields: [userId], references: [id])
  ledgerEntries LedgerEntry[]

  @@index([userId, createdAt])
  @@index([refType, refId])
  @@index([status])
  @@map("payment_orders")
}

model LedgerEntry {
  id             String          @id @default(uuid())
  walletId       String          @map("wallet_id")
  amountCents    Int             @map("amount_cents")
  type           LedgerEntryType
  refType        String?         @map("ref_type")
  refId          String?         @map("ref_id")
  paymentOrderId String?         @map("payment_order_id")
  description    String?
  createdAt      DateTime        @default(now()) @map("created_at")

  wallet       Wallet        @relation(fields: [walletId], references: [id])
  paymentOrder PaymentOrder? @relation(fields: [paymentOrderId], references: [id])

  @@index([walletId, createdAt])
  @@index([paymentOrderId])
  @@map("ledger_entries")
}

model CrowdfundingProject {
  id                String             @id @default(uuid())
  animalId          String             @map("animal_id")
  creatorId         String             @map("creator_id")
  title             String
  description       String?
  goalAmountCents   Int                @map("goal_amount_cents")
  raisedAmountCents Int                @default(0) @map("raised_amount_cents")
  usageDetail       Json               @default("[]") @map("usage_detail")
  status            CrowdfundingStatus @default(draft)
  deadline          DateTime?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  animal  Animal @relation(fields: [animalId], references: [id])
  creator User   @relation(fields: [creatorId], references: [id])

  @@index([animalId])
  @@index([status])
  @@map("crowdfunding_projects")
}

model CloudAdoption {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  animalId  String   @map("animal_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@unique([userId, animalId])
  @@index([userId])
  @@index([animalId])
  @@map("cloud_adoptions")
}

model CareUpdate {
  id        String   @id @default(uuid())
  animalId  String   @map("animal_id")
  authorId  String   @map("author_id")
  content   String
  mediaUrls Json     @default("[]") @map("media_urls")
  createdAt DateTime @default(now()) @map("created_at")

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([animalId, createdAt])
  @@map("care_updates")
}

model Blessing {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  animalId  String   @map("animal_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, createdAt])
  @@index([userId])
  @@map("blessings")
}

model Badge {
  id          String @id @default(uuid())
  code        String @unique
  name        String
  description String
  icon        String

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  badgeId  String   @map("badge_id")
  earnedAt DateTime @default(now()) @map("earned_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model WithdrawalRequest {
  id          String           @id @default(uuid())
  walletId    String           @map("wallet_id")
  requesterId String           @map("requester_id")
  amountCents Int              @map("amount_cents")
  status      WithdrawalStatus @default(pending)
  note        String?
  reviewerId  String?          @map("reviewer_id")
  reviewedAt  DateTime?        @map("reviewed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation(fields: [requesterId], references: [id])

  @@index([status, createdAt])
  @@index([requesterId])
  @@map("withdrawal_requests")
}

model MapPoi {
  id          String     @id @default(uuid())
  cityCode    String     @map("city_code")
  type        MapPoiType
  name        String
  description String?
  latitude    Float
  longitude   Float
  addressText String?    @map("address_text")
  enabled     Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  city City @relation(fields: [cityCode], references: [code])

  @@index([cityCode])
  @@index([type])
  @@index([latitude, longitude])
  @@map("map_pois")
}

model Organization {
  id          String             @id @default(uuid())
  creatorId   String             @map("creator_id")
  cityCode    String             @map("city_code")
  name        String
  description String?
  logoUrl     String?            @map("logo_url")
  status      OrganizationStatus @default(pending)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  creator User                 @relation("OrganizationCreator", fields: [creatorId], references: [id])
  city    City                 @relation(fields: [cityCode], references: [code])
  members OrganizationMember[]
  events  Event[]

  @@index([cityCode])
  @@index([status])
  @@index([creatorId])
  @@map("organizations")
}

model OrganizationMember {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  userId         String        @map("user_id")
  role           OrgMemberRole @default(member)
  createdAt      DateTime      @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Event {
  id                String      @id @default(uuid())
  organizationId    String      @map("organization_id")
  cityCode          String      @map("city_code")
  title             String
  description       String?
  latitude          Float
  longitude         Float
  addressText       String?     @map("address_text")
  startsAt          DateTime    @map("starts_at")
  endsAt            DateTime?   @map("ends_at")
  capacity          Int         @default(50)
  registrationCount Int         @default(0) @map("registration_count")
  status            EventStatus @default(draft)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  organization  Organization        @relation(fields: [organizationId], references: [id])
  city          City                @relation(fields: [cityCode], references: [code])
  registrations EventRegistration[]

  @@index([cityCode, startsAt])
  @@index([organizationId])
  @@index([status])
  @@map("events")
}

model EventRegistration {
  id        String                  @id @default(uuid())
  eventId   String                  @map("event_id")
  userId    String                  @map("user_id")
  status    EventRegistrationStatus @default(registered)
  createdAt DateTime                @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_registrations")
}

model Conversation {
  id        String           @id @default(uuid())
  type      ConversationType @default(direct)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  lastReadAt     DateTime? @map("last_read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String   @db.VarChar(2000)
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}
